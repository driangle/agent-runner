{
  "name": "agentrunner",
  "version": "0.1.0",
  "description": "TypeScript library for programmatically invoking AI coding agents (Claude Code, Gemini CLI, Codex CLI, Ollama)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./claudecode": {
      "types": "./dist/claudecode/index.d.ts",
      "import": "./dist/claudecode/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
